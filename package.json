		"@commitlint/cli": "^20.4.3",
		"@commitlint/config-conventional": "^20.4.3",
		"@types/bun": "^1.3.10",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.2",
		"markdownlint-cli": "^0.48.0"
	},
	"engines": {
		"bun": ">=1.3.9"
	},
	"engineStrict": true,
	"keywords": [],
